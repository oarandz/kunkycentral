      };
      vc.appendChild(r);
    });
    wrap.appendChild(vc);
  }

  if(trip.result) setTimeout(()=>renderTripOut(form.querySelector('#tOut')),0);
  return wrap;
}
function renderTripOut(box){
  const r = trip.result; if(!r) return;
  box.innerHTML = `
    <div class="trip-result">
      <div class="cell"><div class="cv num">${r.miles}</div><div class="cl">miles${r.roundTrip?' (return)':''}</div></div>
      <div class="cell"><div class="cv num">${r.litres}</div><div class="cl">litres</div></div>
      <div class="cell cost"><div class="cv num">${money(r.cost)}</div><div class="cl">fuel cost</div></div>
    </div>
    <div id="map"></div>
    <button class="btn btn-primary btn-block" id="tripToExpense" style="margin-top:14px">Add as expense · ${money(r.cost)}</button>`;
  box.querySelector('#tripToExpense').onclick = ()=>{
    state.tab='add';
    const prefill = { name:`Trip: ${r.origin} → ${r.destination}`, total:r.cost, type:'trip',
      description:`${r.miles} miles${r.roundTrip?' return':''} · ${r.litres} L · ${trip.mpg} mpg @ ${trip.pence}p/L` };
    const v=$('#view'); v.innerHTML=''; v.appendChild(connBanner()); v.appendChild(viewAdd(prefill)); renderTabs();
  };
  setTimeout(()=>drawMap(r),50);
}
function drawMap(r){
  const node = document.getElementById('map'); if(!node||typeof L==='undefined') return;
  if(_map){ _map.remove(); _map=null; }
  _map = L.map(node,{zoomControl:false, attributionControl:false});
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:18}).addTo(_map);
  const a=[r.start.lat,r.start.lng], b=[r.end.lat,r.end.lng];
  const pts = r.polyline ? decodePolyline(r.polyline) : [a,b];
  const line = L.polyline(pts,{color:'#0E7C66',weight:4,opacity:.9}).addTo(_map);
  L.circleMarker(a,{radius:7,color:'#0E7C66',fillColor:'#0E7C66',fillOpacity:1}).addTo(_map);
  L.circleMarker(b,{radius:7,color:'#E5564B',fillColor:'#E5564B',fillOpacity:1}).addTo(_map);
  _map.fitBounds(line.getBounds().pad(0.15));
  setTimeout(()=>_map.invalidateSize(),100);
}
function decodePolyline(str){
  let index=0,lat=0,lng=0,coords=[];
  while(index<str.length){
    let b,shift=0,result=0;
    do{ b=str.charCodeAt(index++)-63; result|=(b&0x1f)<<shift; shift+=5; }while(b>=0x20);
    lat += (result&1)?~(result>>1):(result>>1); shift=0; result=0;
    do{ b=str.charCodeAt(index++)-63; result|=(b&0x1f)<<shift; shift+=5; }while(b>=0x20);
    lng += (result&1)?~(result>>1):(result>>1);
    coords.push([lat/1e5,lng/1e5]);
  }
  return coords;
}
