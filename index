const draft = { receipt:null };
function viewAdd(prefill){
  draft.receipt = null;
  const wrap = el('div');
  wrap.appendChild(el('div','page-title','Add an expense'));
  wrap.appendChild(el('div','page-sub','Log what was spent and split it however you like.'));

  const form = el('div');
  form.innerHTML = `
    <div class="field"><label>Name</label>
      <input class="input" id="exName" placeholder="e.g. Tesco shop" autocomplete="off" value="${esc(prefill&&prefill.name||'')}"></div>
    <div class="field"><label>Amount</label>
      <div class="money-input"><span class="sym">£</span>
      <input class="input" id="exTotal" type="number" inputmode="decimal" step="0.01" placeholder="0.00" value="${prefill&&prefill.total||''}"></div></div>
    <div class="field"><label>Description <span class="hint">optional</span></label>
      <textarea class="input" id="exDesc" placeholder="Anything worth noting">${esc(prefill&&prefill.description||'')}</textarea></div>
    <div class="field"><label>Paid by</label>
      <div class="people-grid" id="paidByGrid"></div></div>
    <div class="field"><label>Split between</label>
      <div class="people-grid" id="splitGrid"></div></div>
    <div class="field"><label>How to split</label>
      <div class="seg" id="splitMode">
        <button data-m="equal" class="active">Split equally</button>
        <button data-m="exact">Exact amounts</button>
      </div>
      <div id="splitDetail" style="margin-top:12px"></div></div>
    <div class="field"><label>Receipt <span class="hint">optional</span></label>
      <label class="upload" for="exFile">
        <div class="ic">📎</div>
        <div><div class="t">Attach a receipt</div><div class="s">Photo or PDF — images are compressed automatically</div></div>
      </label>
      <input type="file" id="exFile" accept="image/*,application/pdf" style="display:none">
      <div id="receiptPrev"></div></div>
    <button class="btn btn-primary btn-block" id="saveExpense">Save expense</button>
  `;
  wrap.appendChild(form);

  // local form state
  const fs = {
    paidBy: prefill&&prefill.paidBy || state.me,
    selected: new Set(prefill&&prefill.split ? Object.keys(prefill.split) : state.people.map(p=>p.name)),
    mode:'equal',
    exact:{}
  };

  function drawPaidBy(){
    const g = form.querySelector('#paidByGrid'); g.innerHTML='';
    state.people.forEach(p=>{
      const b = el('button','pchip'+(fs.paidBy===p.name?' on':''));
      b.innerHTML = `${avatar(p.name,'sm')}${esc(p.name)}<span class="tick">✓</span>`;
      b.onclick = ()=>{ fs.paidBy=p.name; drawPaidBy(); drawDetail(); };
      g.appendChild(b);
    });
  }
  function drawSplit(){
    const g = form.querySelector('#splitGrid'); g.innerHTML='';
    const all = el('button','pchip'+(fs.selected.size===state.people.length?' on':''));
    all.innerHTML = `Everyone<span class="tick">✓</span>`;
    all.onclick = ()=>{
      if(fs.selected.size===state.people.length) fs.selected.clear();
      else state.people.forEach(p=>fs.selected.add(p.name));
      drawSplit(); drawDetail();
    };
    g.appendChild(all);
    state.people.forEach(p=>{
      const b = el('button','pchip'+(fs.selected.has(p.name)?' on':''));
      b.innerHTML = `${avatar(p.name,'sm')}${esc(p.name)}<span class="tick">✓</span>`;
      b.onclick = ()=>{ fs.selected.has(p.name)?fs.selected.delete(p.name):fs.selected.add(p.name); drawSplit(); drawDetail(); };
      g.appendChild(b);
    });
  }
  function currentSplit(){
    const names = [...fs.selected];
    const total = Number(form.querySelector('#exTotal').value)||0;
    if(fs.mode==='equal'){
      const cents = Math.round(total*100), n=names.length||1;
      const base = Math.floor(cents/n); let rem = cents-base*n;
      const out={}; names.forEach((nm,i)=>{ out[nm]=(base+(i<rem?1:0))/100; });
      return {split:out, total, sum:total, ok:names.length>0&&total>0};
    } else {
      const out={}; let sum=0;
      names.forEach(nm=>{ const v=Number(fs.exact[nm])||0; out[nm]=v; sum+=v; });
      return {split:out, total, sum, ok:names.length>0&&total>0&&Math.abs(sum-total)<0.011};
    }
  }
  function drawDetail(){
    const d = form.querySelector('#splitDetail'); d.innerHTML='';
    const names = [...fs.selected];
    if(!names.length){ d.innerHTML='<div class="split-summary bad">Pick at least one person to split between.</div>'; updateSave(); return; }
    const {split,total,sum} = currentSplit();
    if(fs.mode==='equal'){
      const box = el('div','card'); box.style.padding='4px 14px';
      names.forEach(nm=>{
        const r = el('div','split-row');
        r.innerHTML = `${avatar(nm,'sm')}<span class="name">${esc(nm)}</span><span class="num" style="font-weight:600">${money(split[nm])}</span>`;
        box.appendChild(r);
      });
      d.appendChild(box);
      const s = el('div','split-summary good');
      s.innerHTML = `<span>${names.length} ${names.length===1?'person':'people'} · equal shares</span><span class="v num">${money(total)}</span>`;
      d.appendChild(s);
    } else {
      const box = el('div','card'); box.style.padding='4px 14px';
      names.forEach(nm=>{
        const r = el('div','split-row');
        r.innerHTML = `${avatar(nm,'sm')}<span class="name">${esc(nm)}</span>
          <div class="money-input amt"><span class="sym" style="font-size:13px">£</span>
          <input class="input" data-nm="${esc(nm)}" type="number" inputmode="decimal" step="0.01" placeholder="0.00" value="${fs.exact[nm]!=null?fs.exact[nm]:''}" style="padding-left:24px;font-size:15px"></div>`;
        box.appendChild(r);
      });
      d.appendChild(box);
      box.querySelectorAll('input[data-nm]').forEach(inp=>{
        inp.oninput = ()=>{ fs.exact[inp.dataset.nm]=inp.value; const {sum,total}=currentSplit(); updateSummary(sum,total); updateSave(); };
      });
      const diff = total-sum;
      const s = el('div','split-summary '+(Math.abs(diff)<0.011?'good':'bad'));
      s.id='exactSummary';
      s.innerHTML = summaryHTML(sum,total);
      d.appendChild(s);
    }
    updateSave();
  }
  function summaryHTML(sum,total){
    const diff = Math.round((total-sum)*100)/100;
    if(Math.abs(diff)<0.011) return `<span>Adds up perfectly</span><span class="v num">${money(total)}</span>`;
    if(diff>0) return `<span>${money(diff)} left to assign</span><span class="v num">${money(sum)} / ${money(total)}</span>`;
    return `<span>${money(-diff)} over the total</span><span class="v num">${money(sum)} / ${money(total)}</span>`;
  }
  function updateSummary(sum,total){
    const s = form.querySelector('#exactSummary'); if(!s) return;
    const ok = Math.abs(total-sum)<0.011;
    s.className = 'split-summary '+(ok?'good':'bad');
    s.innerHTML = summaryHTML(sum,total);
  }
  function updateSave(){
    const {ok} = currentSplit();
    form.querySelector('#saveExpense').disabled = !ok || !form.querySelector('#exName').value.trim();
  }

  form.querySelector('#splitMode').addEventListener('click', e=>{
    const btn = e.target.closest('button'); if(!btn) return;
    fs.mode = btn.dataset.m;
    [...form.querySelectorAll('#splitMode button')].forEach(b=>b.classList.toggle('active', b===btn));
    drawDetail();
  });
  form.querySelector('#exTotal').addEventListener('input', ()=>{ drawDetail(); });
  form.querySelector('#exName').addEventListener('input', updateSave);

  // receipt
  form.querySelector('#exFile').addEventListener('change', async (e)=>{
    const file = e.target.files[0]; if(!file) return;
    const prev = form.querySelector('#receiptPrev'); prev.innerHTML='<div class="receipt-prev">Processing…</div>';
    try{
      const r = await processFile(file);
      draft.receipt = r;
      prev.innerHTML = `<div class="receipt-prev">
        ${r.preview?`<img src="${r.preview}">`:'<div class="act-ic">📄</div>'}
        <div style="flex:1"><div style="font-weight:600">${esc(r.name)}</div><div style="color:var(--faint);font-size:12px">${(r.size/1024).toFixed(0)} KB</div></div>
        <button class="btn btn-ghost btn-sm" id="rmReceipt">Remove</button></div>`;
      prev.querySelector('#rmReceipt').onclick = ()=>{ draft.receipt=null; prev.innerHTML=''; form.querySelector('#exFile').value=''; };
    }catch(err){ prev.innerHTML=''; toast('Could not read that file','err'); }
  });

  form.querySelector('#saveExpense').onclick = async ()=>{
    const name = form.querySelector('#exName').value.trim();
    const total = Number(form.querySelector('#exTotal').value)||0;
    const desc = form.querySelector('#exDesc').value.trim();
    const {split, ok} = currentSplit();
    if(!ok || !name) return;
    const payload = { name, total, description:desc, paidBy:fs.paidBy, split, type:(prefill&&prefill.type)||'expense' };
    if(draft.receipt) payload.receipt = { data:draft.receipt.data, name:draft.receipt.name, mimeType:draft.receipt.mimeType };
    const btn = form.querySelector('#saveExpense'); btn.disabled=true; btn.innerHTML='<span class="spin"></span>';
    try{
      if(SCRIPT_URL){ applyData(await api('addExpense', payload)); }
      else { state.expenses.unshift({id:'local_'+Date.now(),ts:Date.now(),receiptUrl:'',...payload}); }
      toast('Expense saved'); state.tab='balances'; renderAll();
    }catch(e){ toast(e.message,'err'); btn.disabled=false; btn.innerHTML='Save expense'; }
  };

  setTimeout(()=>{ drawPaidBy(); drawSplit(); drawDetail(); },0);
  return wrap;
}

