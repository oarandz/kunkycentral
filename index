/* ============================================================== *
 *  BALANCES
 * ============================================================== */
function viewBalances(){
  const wrap = el('div');
  const {rows, overall} = computeBalances();

  const kind = Math.abs(overall)<0.01 ? 'zero' : (overall>0?'pos':'neg');
  const card = el('div','overall '+kind);
  let lbl, big, sub;
  if(kind==='zero'){ lbl='All square'; big=money(0); sub='Nobody owes anybody anything right now.'; }
  else if(kind==='pos'){ lbl='You are owed, overall'; big=money(overall); sub='Across everyone in the group.'; }
  else { lbl='You owe, overall'; big=money(Math.abs(overall)); sub='Across everyone in the group.'; }
  card.innerHTML = `<div class="lbl">${lbl}</div><div class="big num">${big}</div><div class="sub">${sub}</div>`;
  wrap.appendChild(card);

  wrap.appendChild(el('div','section-eyebrow','Person by person'));
  const list = el('div','card');
  const sorted = rows.slice().sort((a,b)=>Math.abs(b.net)-Math.abs(a.net));
  if(!sorted.length){
    list.appendChild(emptyState('🫶','Just you so far','Add more people to start splitting.'));
  } else {
    const max = Math.max(1, ...sorted.map(r=>Math.abs(r.net)));
    sorted.forEach(r=>{
      const row = el('div','bal-row');
      const settled = Math.abs(r.net)<0.01;
      const dir = settled?'zero':(r.net>0?'pos':'neg');
      const pct = Math.min(100, (Math.abs(r.net)/max)*100);
      const fill = dir==='zero' ? '' :
        (dir==='pos'
          ? `<div class="fill" style="left:50%;width:${pct/2}%;background:var(--pos)"></div>`
          : `<div class="fill" style="right:50%;width:${pct/2}%;background:var(--neg)"></div>`);
      row.innerHTML = `
        ${avatar(r.name,'md')}
        <div class="bal-info">
          <div class="nm">${esc(r.name)}</div>
          <div class="meta">${settled?'Settled up':(r.net>0?'owes you':'you owe')}</div>
          <div class="flow"><div class="fill" style="left:50%;width:1px;background:var(--line)"></div>${fill}</div>
        </div>
        <div class="bal-amt">
          <div class="v ${dir==='pos'?'pos-c':dir==='neg'?'neg-c':'zero-c'} num">${settled?'—':money(Math.abs(r.net))}</div>
          <div class="d ${dir==='pos'?'pos-c':dir==='neg'?'neg-c':'zero-c'}">${settled?'':(r.net>0?'owed':'you owe')}</div>
        </div>`;
      row.onclick = ()=>personDetailSheet(r.name);
      list.appendChild(row);
    });
  }
  wrap.appendChild(list);
  return wrap;
}

function personDetailSheet(other){
  const shared = state.expenses.filter(x=> x.split && (x.split[other]!=null || x.split[state.me]!=null) && (x.paidBy===other||x.paidBy===state.me) && (x.split[other]!=null && x.paidBy===state.me || x.split[state.me]!=null && x.paidBy===other));
  openSheet(s=>{
    s.appendChild(el('h2',null,`You & ${esc(other)}`));
    s.appendChild(el('p','desc','Expenses between the two of you.'));
    if(!shared.length){ s.appendChild(emptyState('🧾','Nothing shared yet','No expenses link you two so far.')); return; }
    const list = el('div','card'); list.style.marginBottom='8px';
    shared.forEach(x=>{
      const youPaid = x.paidBy===state.me;
      const amt = youPaid ? (x.split[other]||0) : (x.split[state.me]||0);
      const row = el('div','act-row');
      row.innerHTML = `<div class="act-ic">${typeIcon(x)}</div>
        <div class="act-main"><div class="at">${esc(x.name)}</div>
        <div class="am">${youPaid?'You paid · they owe':'They paid · you owe'}</div></div>
        <div class="act-right"><div class="tot num ${youPaid?'pos-c':'neg-c'}">${money(amt)}</div></div>`;
      list.appendChild(row);
    });
    s.appendChild(list);
  });
}

