/* ---------------- File processing ---------------- */
function processFile(file){
  return new Promise((resolve,reject)=>{
    if(file.type.startsWith('image/')){
      const img=new Image(), reader=new FileReader();
      reader.onload=()=>{ img.onload=()=>{
        const max=1400; let {width:w,height:h}=img;
        if(w>max||h>max){ const sc=max/Math.max(w,h); w=Math.round(w*sc); h=Math.round(h*sc); }
        const c=document.createElement('canvas'); c.width=w; c.height=h;
        c.getContext('2d').drawImage(img,0,0,w,h);
        const dataUrl=c.toDataURL('image/jpeg',0.82);
        const b64=dataUrl.split(',')[1];
        resolve({data:b64, name:file.name.replace(/\.[^.]+$/,'')+'.jpg', mimeType:'image/jpeg', size:Math.round(b64.length*0.75), preview:dataUrl});
      }; img.onerror=reject; img.src=reader.result; };
      reader.onerror=reject; reader.readAsDataURL(file);
    } else {
      const reader=new FileReader();
      reader.onload=()=>{ const b64=reader.result.split(',')[1];
        resolve({data:b64, name:file.name, mimeType:file.type||'application/octet-stream', size:file.size, preview:null}); };
      reader.onerror=reject; reader.readAsDataURL(file);
    }
  });
}

