<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Split — shared expenses</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css">
<style>
  :root{
    --ink:#181B23; --ink-soft:#3A3F4B; --muted:#717784; --faint:#9AA0AC;
    --canvas:#EEF1F4; --card:#FFFFFF; --line:#E4E7EC; --line-soft:#EEF0F3;
    --brand:#0E7C66; --brand-ink:#0A5C4C;
    --pos:#1DAA6B; --pos-soft:#E6F6EF;
    --neg:#E5564B; --neg-soft:#FCEBE9;
    --shadow:0 1px 2px rgba(16,24,40,.04), 0 8px 24px rgba(16,24,40,.06);
    --shadow-lg:0 12px 40px rgba(16,24,40,.16);
    --r:16px; --r-sm:11px; --r-lg:22px;
    --display:'Space Grotesk',system-ui,sans-serif;
    --body:'Inter',system-ui,sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:var(--body); color:var(--ink); background:var(--canvas);
    -webkit-font-smoothing:antialiased; line-height:1.45;
    overflow-x:hidden;
  }
  .num{font-family:var(--display); font-feature-settings:"tnum" 1; letter-spacing:-.01em}
  button{font-family:inherit; cursor:pointer; border:none; background:none; color:inherit}
  input,textarea,select{font-family:inherit; font-size:16px; color:var(--ink)}
  :focus-visible{outline:2px solid var(--brand); outline-offset:2px; border-radius:6px}
  ::selection{background:#0E7C6633}

  /* ---------- App frame ---------- */
  #app{max-width:560px; margin:0 auto; min-height:100dvh; display:flex; flex-direction:column}

  .topbar{
    position:sticky; top:0; z-index:30; background:rgba(238,241,244,.85);
    backdrop-filter:saturate(1.4) blur(12px); -webkit-backdrop-filter:saturate(1.4) blur(12px);
    padding:14px 18px 12px; display:flex; align-items:center; gap:12px;
    border-bottom:1px solid var(--line);
  }
  .wordmark{font-family:var(--display); font-weight:700; font-size:21px; letter-spacing:-.03em; display:flex; align-items:center; gap:8px}
  .wordmark .dot{width:10px; height:10px; border-radius:50%; background:var(--brand); box-shadow:0 0 0 4px #0E7C6622}
  .topbar .spacer{flex:1}
  .me-chip{display:flex; align-items:center; gap:8px; background:var(--card); border:1px solid var(--line);
    padding:5px 11px 5px 5px; border-radius:999px; font-weight:600; font-size:13px; box-shadow:var(--shadow)}
  .me-chip:active{transform:scale(.97)}

  main{flex:1; padding:18px 18px 110px}

  /* ---------- Connection banner ---------- */
  .conn{background:var(--card); border:1px solid var(--line); border-radius:var(--r); padding:14px 16px; margin-bottom:16px; box-shadow:var(--shadow)}
  .conn.ok{border-color:#1DAA6B55; background:var(--pos-soft)}
  .conn-head{display:flex; align-items:center; gap:10px; cursor:pointer}
  .conn-head h3{font-size:14px; font-weight:600}
  .conn-head .status{margin-left:auto; font-size:12px; font-weight:600; color:var(--muted); display:flex; align-items:center; gap:6px}
  .conn-head .status .led{width:8px; height:8px; border-radius:50%; background:var(--neg)}
  .conn.ok .status .led{background:var(--pos)}
  .conn-body{margin-top:12px}
  .conn p{font-size:13px; color:var(--muted); margin-bottom:10px; line-height:1.5}
  .conn .row{display:flex; gap:8px}
  .conn input{flex:1; padding:11px 13px; border:1px solid var(--line); border-radius:var(--r-sm); background:#fff}

  /* ---------- Avatars ---------- */
  .av{display:inline-flex; align-items:center; justify-content:center; border-radius:50%; color:#fff;
    font-weight:600; font-family:var(--body); flex:none; line-height:1}
  .av.sm{width:30px; height:30px; font-size:12px}
  .av.md{width:40px; height:40px; font-size:15px}
  .av.lg{width:58px; height:58px; font-size:21px}

  /* ---------- Buttons ---------- */
  .btn{display:inline-flex; align-items:center; justify-content:center; gap:8px; font-weight:600; font-size:15px;
    padding:13px 18px; border-radius:var(--r-sm); transition:transform .08s ease, background .15s ease, box-shadow .15s}
  .btn:active{transform:scale(.98)}
  .btn-primary{background:var(--brand); color:#fff; box-shadow:0 1px 2px rgba(14,124,102,.4), 0 6px 16px rgba(14,124,102,.22)}
  .btn-primary:hover{background:var(--brand-ink)}
  .btn-primary:disabled{background:#C7CDD4; box-shadow:none; cursor:not-allowed; color:#fff}
  .btn-ghost{background:var(--card); border:1px solid var(--line); color:var(--ink); box-shadow:var(--shadow)}
  .btn-ghost:hover{border-color:#cfd4db}
  .btn-block{width:100%}
  .btn-sm{padding:9px 13px; font-size:13px; border-radius:9px}

  /* ---------- Cards / sections ---------- */
  .card{background:var(--card); border:1px solid var(--line); border-radius:var(--r); box-shadow:var(--shadow)}
  .section-eyebrow{font-size:11px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--faint); margin:2px 0 12px}
  .page-title{font-family:var(--display); font-weight:700; font-size:26px; letter-spacing:-.025em; margin-bottom:2px}
  .page-sub{font-size:14px; color:var(--muted); margin-bottom:20px}

  /* ---------- Forms ---------- */
  .field{margin-bottom:16px}
  .field label{display:block; font-size:13px; font-weight:600; color:var(--ink-soft); margin-bottom:7px}
  .field .hint{font-weight:400; color:var(--faint)}
  .input, textarea.input, select.input{width:100%; padding:13px 14px; border:1px solid var(--line); border-radius:var(--r-sm);
    background:#fff; transition:border .15s, box-shadow .15s}
  .input:focus, textarea.input:focus, select.input:focus{outline:none; border-color:var(--brand); box-shadow:0 0 0 3px #0E7C661f}
  textarea.input{resize:vertical; min-height:70px; line-height:1.5}
  .money-input{position:relative}
  .money-input .sym{position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--muted); font-weight:600; font-family:var(--display)}
  .money-input input{padding-left:30px; font-family:var(--display); font-size:18px; font-weight:600}

  /* segmented control */
  .seg{display:flex; background:var(--canvas); border:1px solid var(--line); border-radius:var(--r-sm); padding:4px; gap:4px}
  .seg button{flex:1; padding:9px; border-radius:8px; font-size:13.5px; font-weight:600; color:var(--muted); transition:.15s}
  .seg button.active{background:#fff; color:var(--ink); box-shadow:var(--shadow)}

  /* person picker chips */
  .people-grid{display:flex; flex-wrap:wrap; gap:8px}
  .pchip{display:inline-flex; align-items:center; gap:8px; padding:6px 13px 6px 6px; border-radius:999px;
    border:1.5px solid var(--line); background:#fff; font-size:14px; font-weight:600; color:var(--ink-soft); transition:.12s}
  .pchip:active{transform:scale(.96)}
  .pchip.on{border-color:var(--brand); background:#0E7C660d; color:var(--ink)}
  .pchip .tick{margin-left:2px; color:var(--brand); opacity:0; transition:.12s; font-size:13px}
  .pchip.on .tick{opacity:1}

  .split-row{display:flex; align-items:center; gap:11px; padding:10px 0; border-bottom:1px solid var(--line-soft)}
  .split-row:last-child{border-bottom:none}
  .split-row .name{flex:1; font-weight:500; font-size:14.5px}
  .split-row .amt{width:104px}
  .split-summary{display:flex; justify-content:space-between; align-items:baseline; padding:12px 14px; border-radius:var(--r-sm);
    background:var(--canvas); font-size:13.5px; margin-top:8px}
  .split-summary.bad{background:var(--neg-soft); color:#A8392F}
  .split-summary.good{background:var(--pos-soft); color:#0F7A4E}
  .split-summary .v{font-family:var(--display); font-weight:700; font-size:16px}

  .upload{display:flex; align-items:center; gap:12px; padding:14px; border:1.5px dashed var(--line); border-radius:var(--r-sm);
    background:#fafbfc; cursor:pointer; transition:.15s}
  .upload:hover{border-color:var(--brand); background:#0E7C6608}
  .upload .ic{width:38px; height:38px; border-radius:10px; background:var(--canvas); display:grid; place-items:center; flex:none}
  .upload .t{font-size:13.5px; font-weight:600}
  .upload .s{font-size:12px; color:var(--faint)}
  .receipt-prev{display:flex; align-items:center; gap:10px; margin-top:10px; font-size:13px; background:var(--canvas); padding:8px 10px; border-radius:10px}
  .receipt-prev img{width:44px; height:44px; object-fit:cover; border-radius:8px}

  /* ---------- Balances ---------- */
  .overall{padding:22px 20px; border-radius:var(--r-lg); color:#fff; margin-bottom:18px; position:relative; overflow:hidden}
  .overall.pos{background:linear-gradient(135deg,#15A06A,#0E7C66)}
  .overall.neg{background:linear-gradient(135deg,#E5564B,#C53A30)}
  .overall.zero{background:linear-gradient(135deg,#3A4250,#272D38)}
  .overall .lbl{font-size:13px; opacity:.85; font-weight:500}
  .overall .big{font-family:var(--display); font-weight:700; font-size:42px; letter-spacing:-.03em; line-height:1.1; margin-top:4px}
  .overall .sub{font-size:13px; opacity:.85; margin-top:6px}
  .overall::after{content:""; position:absolute; right:-40px; top:-40px; width:160px; height:160px; border-radius:50%; background:rgba(255,255,255,.08)}

  .bal-row{display:flex; align-items:center; gap:13px; padding:15px 16px; border-bottom:1px solid var(--line-soft)}
  .bal-row:last-child{border-bottom:none}
  .bal-info{flex:1; min-width:0}
  .bal-info .nm{font-weight:600; font-size:15px}
  .bal-info .meta{font-size:12.5px; color:var(--faint)}
  .flow{height:6px; background:var(--canvas); border-radius:99px; margin-top:8px; position:relative; overflow:hidden}
  .flow .fill{position:absolute; top:0; bottom:0; border-radius:99px}
  .bal-amt{text-align:right; flex:none}
  .bal-amt .v{font-family:var(--display); font-weight:700; font-size:17px}
  .bal-amt .d{font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.04em}
  .pos-c{color:var(--pos)} .neg-c{color:var(--neg)} .zero-c{color:var(--faint)}

  /* ---------- Quick ---------- */
  .quick-grid{display:grid; grid-template-columns:1fr 1fr; gap:11px}
  .quick-btn{background:var(--card); border:1px solid var(--line); border-radius:var(--r); padding:16px; text-align:left;
    box-shadow:var(--shadow); transition:transform .08s, box-shadow .15s; position:relative}
  .quick-btn:active{transform:scale(.97)}
  .quick-btn:hover{box-shadow:var(--shadow-lg)}
  .quick-btn .emo{font-size:26px; display:block; margin-bottom:8px}
  .quick-btn .ql{font-weight:600; font-size:14.5px}
  .quick-btn .qa{font-family:var(--display); font-weight:700; font-size:18px; margin-top:3px}
  .quick-btn .qs{font-size:11.5px; color:var(--faint); margin-top:2px}
  .quick-btn .del{position:absolute; top:8px; right:8px; width:24px; height:24px; border-radius:50%; background:var(--canvas);
    display:grid; place-items:center; color:var(--muted); font-size:13px; opacity:0; transition:.15s}
  .quick-btn:hover .del{opacity:1}
  .quick-add{border:1.5px dashed var(--line); background:transparent; box-shadow:none; display:grid; place-items:center; color:var(--muted); min-height:118px; font-weight:600; font-size:14px}
  .quick-add:hover{border-color:var(--brand); color:var(--brand)}

  /* ---------- Trip ---------- */
  .trip-route{display:flex; gap:12px; align-items:stretch}
  .trip-route .pins{display:flex; flex-direction:column; align-items:center; padding-top:14px}
  .trip-route .pin{width:11px; height:11px; border-radius:50%; border:2.5px solid var(--brand)}
  .trip-route .pin.end{border-color:var(--neg); border-radius:50% 50% 50% 0; transform:rotate(45deg)}
  .trip-route .line{flex:1; width:2px; background:repeating-linear-gradient(var(--line) 0 4px, transparent 4px 8px); margin:4px 0}
  .trip-route .inputs{flex:1}
  #map{height:200px; border-radius:var(--r); margin-top:14px; border:1px solid var(--line); background:var(--canvas); z-index:0}
  .trip-result{display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--line); border-radius:var(--r); overflow:hidden; margin-top:14px}
  .trip-result .cell{background:#fff; padding:14px 12px; text-align:center}
  .trip-result .cv{font-family:var(--display); font-weight:700; font-size:21px}
  .trip-result .cl{font-size:11px; color:var(--faint); margin-top:2px; text-transform:uppercase; letter-spacing:.05em}
  .trip-result .cell.cost .cv{color:var(--brand)}

  .veh-row{display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid var(--line-soft)}
  .veh-row:last-child{border-bottom:none}
  .veh-row .vn{font-weight:600; font-size:14.5px}
  .veh-row .vm{font-size:12.5px; color:var(--faint)}

  /* ---------- Activity ---------- */
  .act-row{display:flex; align-items:center; gap:13px; padding:14px 16px; border-bottom:1px solid var(--line-soft)}
  .act-row:last-child{border-bottom:none}
  .act-ic{width:42px; height:42px; border-radius:12px; background:var(--canvas); display:grid; place-items:center; font-size:19px; flex:none}
  .act-main{flex:1; min-width:0}
  .act-main .at{font-weight:600; font-size:14.5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis}
  .act-main .am{font-size:12.5px; color:var(--faint)}
  .act-right{text-align:right; flex:none}
  .act-right .tot{font-family:var(--display); font-weight:700; font-size:15px}
  .act-right .yr{font-size:11.5px; color:var(--muted)}

  /* ---------- Tab bar ---------- */
  .tabbar{position:fixed; bottom:0; left:0; right:0; z-index:40; display:flex; justify-content:center; pointer-events:none}
  .tabbar .inner{pointer-events:auto; display:flex; gap:2px; background:rgba(24,27,35,.92); backdrop-filter:blur(12px);
    margin-bottom:max(14px,env(safe-area-inset-bottom)); padding:6px; border-radius:999px; box-shadow:var(--shadow-lg)}
  .tab{display:flex; flex-direction:column; align-items:center; gap:3px; padding:8px 14px; border-radius:999px; color:#9AA0AC; transition:.15s; min-width:58px}
  .tab svg{width:21px; height:21px}
  .tab span{font-size:10px; font-weight:600}
  .tab.active{background:#fff; color:var(--ink)}

  /* ---------- Login ---------- */
  .login{min-height:100dvh; display:flex; flex-direction:column; justify-content:center; padding:32px 24px; max-width:480px; margin:0 auto}
  .login .hero{text-align:center; margin-bottom:36px}
  .login .hero .mk{font-family:var(--display); font-weight:700; font-size:40px; letter-spacing:-.04em; display:inline-flex; align-items:center; gap:11px}
  .login .hero .mk .dot{width:14px;height:14px;border-radius:50%;background:var(--brand);box-shadow:0 0 0 6px #0E7C661f}
  .login .hero p{color:var(--muted); margin-top:10px; font-size:15px}
  .login .who{font-size:12px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--faint); text-align:center; margin-bottom:18px}
  .who-grid{display:grid; grid-template-columns:1fr 1fr; gap:11px}
  .who-card{background:var(--card); border:1px solid var(--line); border-radius:var(--r); padding:18px 16px; display:flex; align-items:center; gap:13px;
    box-shadow:var(--shadow); transition:transform .08s, box-shadow .15s; text-align:left}
  .who-card:hover{box-shadow:var(--shadow-lg)}
  .who-card:active{transform:scale(.97)}
  .who-card .nm{font-weight:600; font-size:16px}
  .who-add{grid-column:1/-1; border:1.5px dashed var(--line); background:transparent; box-shadow:none; justify-content:center; color:var(--muted); font-weight:600; padding:15px}
  .who-add:hover{border-color:var(--brand); color:var(--brand)}

  /* ---------- Modal / sheet ---------- */
  .overlay{position:fixed; inset:0; background:rgba(17,20,28,.5); z-index:50; display:flex; align-items:flex-end; justify-content:center;
    opacity:0; pointer-events:none; transition:opacity .2s}
  .overlay.show{opacity:1; pointer-events:auto}
  .sheet{background:var(--card); width:100%; max-width:560px; border-radius:var(--r-lg) var(--r-lg) 0 0; padding:8px 20px 24px;
    max-height:90dvh; overflow-y:auto; transform:translateY(100%); transition:transform .26s cubic-bezier(.32,.72,0,1)}
  .overlay.show .sheet{transform:translateY(0)}
  .sheet .grip{width:38px; height:4px; background:var(--line); border-radius:99px; margin:8px auto 14px}
  .sheet h2{font-family:var(--display); font-weight:700; font-size:21px; letter-spacing:-.02em; margin-bottom:4px}
  .sheet .desc{font-size:13.5px; color:var(--muted); margin-bottom:18px}

  /* ---------- Toast ---------- */
  #toasts{position:fixed; top:14px; left:0; right:0; z-index:60; display:flex; flex-direction:column; align-items:center; gap:8px; pointer-events:none}
  .toast{background:var(--ink); color:#fff; padding:11px 18px; border-radius:999px; font-size:13.5px; font-weight:500;
    box-shadow:var(--shadow-lg); display:flex; align-items:center; gap:9px; transform:translateY(-16px); opacity:0; transition:.25s}
  .toast.show{transform:translateY(0); opacity:1}
  .toast.err{background:var(--neg)}
  .toast.ok .ic{color:#5BE3A5}

  .empty{text-align:center; padding:48px 20px; color:var(--faint)}
  .empty .e-ic{font-size:34px; margin-bottom:10px}
  .empty .e-t{font-weight:600; color:var(--muted); font-size:15px}
  .empty .e-s{font-size:13.5px; margin-top:4px}

  .spin{width:18px; height:18px; border:2.5px solid #ffffff55; border-top-color:#fff; border-radius:50%; animation:sp .7s linear infinite; display:inline-block}
  @keyframes sp{to{transform:rotate(360deg)}}
  .skeleton{background:linear-gradient(90deg,#e9ecf0 25%,#f2f4f7 50%,#e9ecf0 75%); background-size:200% 100%; animation:sk 1.3s infinite; border-radius:8px}
  @keyframes sk{to{background-position:-200% 0}}

  @media (max-width:380px){ .quick-grid,.who-grid{grid-template-columns:1fr} }
  @media (prefers-reduced-motion:reduce){ *{animation-duration:.001ms!important; transition-duration:.001ms!important} }
</style>
</head>
<body>

<div id="login" class="login"></div>

<div id="app" style="display:none">
  <div class="topbar">
    <div class="wordmark"><span class="dot"></span>Split</div>
    <div class="spacer"></div>
    <button class="me-chip" id="meChip"></button>
  </div>
  <main id="view"></main>
  <nav class="tabbar"><div class="inner" id="tabbar"></div></nav>
</div>

<div class="overlay" id="overlay"><div class="sheet" id="sheet"></div></div>
<div id="toasts"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js"></script>
<script>
/* ============================================================== *
 *  PASTE YOUR WEB APP URL HERE (ends in /exec) — or use the
 *  connection box at the top of the app. Leaving it blank just
 *  means the app runs in preview mode until you connect.
 * ============================================================== */
let SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyiDoq6R8czEa6iymh_t0zrupUwvQGrLaX5IS2ScTFhAuaUQdl5yCTjgFOUq4QgiSMH/exec";

// Must match SHARED_SECRET in Code.gs exactly.
const SHARED_SECRET = "split-7f3a9c2e8b1d4056";

/* ---------------- State ---------------- */
const PALETTE = ['#E5564B','#1DAA6B','#3B82F6','#F59E0B','#8B5CF6','#EC4899','#0EA5E9','#14B8A6','#F97316','#6366F1'];
const SEED_PEOPLE = ['Owen','Alex','Conor','Ben','Alice','Lucy'];
const state = {
  people: SEED_PEOPLE.map((n,i)=>({name:n,color:PALETTE[i%PALETTE.length]})),
  vehicles: [], quick: [], expenses: [],
  me: null, tab: 'balances', connected: false, loading: false
};

/* ---------------- Helpers ---------------- */
const $ = s => document.querySelector(s);
const el = (tag, cls, html) => { const e=document.createElement(tag); if(cls) e.className=cls; if(html!=null) e.innerHTML=html; return e; };
const esc = s => String(s==null?'':s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const money = n => '£'+(Math.round(Number(n)*100)/100).toFixed(2);
const initials = n => n.trim().split(/\s+/).map(w=>w[0]).slice(0,2).join('').toUpperCase();
const personColor = n => (state.people.find(p=>p.name===n)||{}).color || '#717784';
const avatar = (name, size='sm') => `<span class="av ${size}" style="background:${personColor(name)}">${esc(initials(name))}</span>`;

/* ---------------- Backend ---------------- */
async function api(action, payload){
  if(!SCRIPT_URL) throw new Error('Not connected. Add your Web app URL up top.');
  const res = await fetch(SCRIPT_URL, {
    method:'POST', redirect:'follow',
    headers:{'Content-Type':'text/plain;charset=utf-8'},
    body: JSON.stringify({action, payload: payload||{}, secret: SHARED_SECRET})
  });
  const out = await res.json();
  if(!out.ok) throw new Error(out.error||'Something went wrong');
  return out.data;
}
function applyData(d){
  if(!d) return;
  state.people = d.people && d.people.length ? d.people : state.people;
  state.vehicles = d.vehicles || [];
  state.quick = d.quick || [];
  state.expenses = (d.expenses||[]).sort((a,b)=>b.ts-a.ts);
  if(state.me && !state.people.some(p=>p.name===state.me)) state.me = null;
}
async function refresh(){
  if(!SCRIPT_URL) return;
  try{ state.loading=true; const d = await api('getData'); state.connected=true; applyData(d); }
  catch(e){ state.connected=false; toast(e.message,'err'); }
  finally{ state.loading=false; renderAll(); }
}

/* ---------------- Toast ---------------- */
function toast(msg, kind='ok'){
  const t = el('div','toast '+kind);
  const ic = kind==='err' ? '✕' : '✓';
  t.innerHTML = `<span class="ic">${ic}</span>${esc(msg)}`;
  $('#toasts').appendChild(t);
  requestAnimationFrame(()=>t.classList.add('show'));
  setTimeout(()=>{ t.classList.remove('show'); setTimeout(()=>t.remove(),300); }, 2800);
}

/* ---------------- Sheet / modal ---------------- */
function openSheet(builder){
  const sheet = $('#sheet'); sheet.innerHTML='<div class="grip"></div>';
  builder(sheet);
  $('#overlay').classList.add('show');
}
function closeSheet(){ $('#overlay').classList.remove('show'); }
$('#overlay').addEventListener('click', e=>{ if(e.target.id==='overlay') closeSheet(); });

/* ---------------- Balance maths ---------------- */
function computeBalances(){
  // debt[a][b] = how much a owes b
  const debt = {};
  state.people.forEach(p=>{ debt[p.name]={}; });
  state.expenses.forEach(x=>{
    const payer = x.paidBy;
    Object.keys(x.split||{}).forEach(person=>{
      if(person===payer) return;
      if(!debt[person]) debt[person]={};
      debt[person][payer] = (debt[person][payer]||0) + (Number(x.split[person])||0);
    });
  });
  // net for me vs each other person
  const me = state.me;
  const rows = [];
  state.people.filter(p=>p.name!==me).forEach(p=>{
    const o = p.name;
    const theyOweMe = (debt[o] && debt[o][me]) || 0;
    const iOweThem  = (debt[me] && debt[me][o]) || 0;
    const net = theyOweMe - iOweThem; // >0 they owe me
    rows.push({name:o, net});
  });
  const overall = rows.reduce((s,r)=>s+r.net,0);
  return {rows, overall};
}

