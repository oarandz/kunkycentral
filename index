    const f = el('div','field'); f.innerHTML='<label>Paid by</label><div class="people-grid" id="qPaid"></div>';
    s.appendChild(f);
    const draw = ()=>{ const g=f.querySelector('#qPaid'); g.innerHTML='';
      state.people.forEach(p=>{ const b=el('button','pchip'+(fs.paidBy===p.name?' on':''));
        b.innerHTML=`${avatar(p.name,'sm')}${esc(p.name)}<span class="tick">✓</span>`;
        b.onclick=()=>{fs.paidBy=p.name; draw();}; g.appendChild(b); }); };
    draw();
    const info = el('div','split-summary good');
    info.innerHTML = `<span>Split equally · ${names.length} people</span><span class="v num">${money(q.amount)}</span>`;
    s.appendChild(info);
    const btn = el('button','btn btn-primary btn-block','Log '+money(q.amount)); btn.style.marginTop='14px';
    btn.onclick = async ()=>{
      const cents=Math.round(q.amount*100), n=names.length||1, base=Math.floor(cents/n); let rem=cents-base*n;
      const split={}; names.forEach((nm,i)=>split[nm]=(base+(i<rem?1:0))/100);
      const payload={ name:q.label, total:q.amount, description:q.description||'', paidBy:fs.paidBy, split, type:'quick' };
      btn.disabled=true; btn.innerHTML='<span class="spin"></span>';
      try{
        if(SCRIPT_URL){ applyData(await api('addExpense',payload)); }
        else { state.expenses.unshift({id:'local_'+Date.now(),ts:Date.now(),receiptUrl:'',...payload}); }
        closeSheet(); toast(q.label+' logged'); state.tab='balances'; renderAll();
      }catch(e){ toast(e.message,'err'); btn.disabled=false; btn.innerHTML='Log '+money(q.amount); }
    };
    s.appendChild(btn);
  });
}
