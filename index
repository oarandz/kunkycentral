let _map, _layer;
const trip = { origin:'', destination:'', vehicle:null, mpg:'', pence:'145', roundTrip:false, result:null };
function viewTrip(){
  const wrap = el('div');
  wrap.appendChild(el('div','page-title','Trip cost'));
  wrap.appendChild(el('div','page-sub','Work out the fuel for a journey, then split it like any expense.'));

  const form = el('div','card'); form.style.padding='16px';
  form.innerHTML = `
    <div class="trip-route">
      <div class="pins"><span class="pin"></span><span class="line"></span><span class="pin end"></span></div>
      <div class="inputs">
        <div class="field" style="margin-bottom:10px"><input class="input" id="tFrom" placeholder="Start — e.g. Tyldesley" value="${esc(trip.origin)}"></div>
        <div class="field" style="margin-bottom:0"><input class="input" id="tTo" placeholder="Destination — e.g. Manchester" value="${esc(trip.destination)}"></div>
      </div>
    </div>
    <div class="field" style="margin-top:16px"><label>Vehicle</label>
      <select class="input" id="tVehicle"></select></div>
    <div style="display:flex;gap:12px">
      <div class="field" style="flex:1"><label>MPG</label><input class="input" id="tMpg" type="number" inputmode="decimal" placeholder="e.g. 45" value="${esc(trip.mpg)}"></div>
      <div class="field" style="flex:1"><label>Fuel <span class="hint">p/litre</span></label><input class="input" id="tPence" type="number" inputmode="decimal" placeholder="145" value="${esc(trip.pence)}"></div>
    </div>
    <div class="field"><label style="display:flex;align-items:center;gap:9px;cursor:pointer">
      <input type="checkbox" id="tRound" ${trip.roundTrip?'checked':''} style="width:18px;height:18px;accent-color:var(--brand)"> Return journey (there and back)
    </label></div>
    <button class="btn btn-primary btn-block" id="tCalc">Calculate fuel cost</button>
    <div id="tOut"></div>
  `;
  wrap.appendChild(form);

  // vehicle select
  const sel = form.querySelector('#tVehicle');
  sel.innerHTML = `<option value="">— Manual entry —</option>` + state.vehicles.map(v=>`<option value="${esc(v.name)}">${esc(v.name)} · ${v.mpg} mpg</option>`).join('') + `<option value="__add">+ Save a vehicle…</option>`;
  sel.onchange = ()=>{
    if(sel.value==='__add'){ sel.value=trip.vehicle||''; vehicleEditorSheet(); return; }
    trip.vehicle = sel.value;
    const v = state.vehicles.find(x=>x.name===sel.value);
    if(v){ form.querySelector('#tMpg').value=v.mpg||''; if(v.pence) form.querySelector('#tPence').value=v.pence; }
  };
  if(trip.vehicle) sel.value=trip.vehicle;

  form.querySelector('#tCalc').onclick = async ()=>{
    trip.origin = form.querySelector('#tFrom').value.trim();
    trip.destination = form.querySelector('#tTo').value.trim();
    trip.mpg = form.querySelector('#tMpg').value;
    trip.pence = form.querySelector('#tPence').value;
    trip.roundTrip = form.querySelector('#tRound').checked;
    if(!trip.origin||!trip.destination) return toast('Enter both places','err');
    if(!(Number(trip.mpg)>0)) return toast('Enter the MPG','err');
    if(!SCRIPT_URL) return toast('Connect your sheet to use the map — it does the distance maths.','err');
    const btn = form.querySelector('#tCalc'); btn.disabled=true; btn.innerHTML='<span class="spin"></span> Mapping route…';
    try{
      const r = await api('calcTrip',{origin:trip.origin, destination:trip.destination, mpg:Number(trip.mpg), pence:Number(trip.pence), roundTrip:trip.roundTrip});
      trip.result = r; renderTripOut(form.querySelector('#tOut'));
    }catch(e){ toast(e.message,'err'); }
    finally{ btn.disabled=false; btn.innerHTML='Calculate fuel cost'; }
  };

  // manage vehicles list
  if(state.vehicles.length){
    wrap.appendChild(el('div','section-eyebrow','Saved vehicles'));
    const vc = el('div','card'); vc.style.padding='4px 16px';
    state.vehicles.forEach(v=>{
      const r = el('div','veh-row');
      r.innerHTML = `<div class="act-ic">🚗</div><div style="flex:1"><div class="vn">${esc(v.name)}</div>
        <div class="vm">${v.mpg} mpg${v.pence?` · ${v.pence}p/litre`:''}</div></div>
        <button class="btn btn-ghost btn-sm vdel">Remove</button>`;
      r.querySelector('.vdel').onclick = async ()=>{
        if(SCRIPT_URL){ try{ applyData(await api('deleteVehicle',{name:v.name})); toast('Removed'); }catch(e){ toast(e.message,'err'); } }
        else { state.vehicles=state.vehicles.filter(x=>x!==v); }
